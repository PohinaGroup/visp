DATABASE_URL=postgresql://visp:visp@127.0.0.1:5432/visp
# Optional: PEM CA for managed Postgres (UpCloud). Omit for local Postgres.
# DATABASE_SSL_CA=/etc/visp/upcloud-db-ca.crt
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
BETTER_AUTH_URL=http://127.0.0.1:3000
CORS_ORIGIN=http://127.0.0.1:3001
HOOK_SECRET=replace-with-at-least-32-random-characters
# Kick OAuth, app-token subscriptions, and signed chat webhooks.
KICK_CLIENT_ID=
KICK_CLIENT_SECRET=
MEDIAMTX_API_URL=http://100.64.0.10:9997
NATIVE_WEB_ORIGIN=http://127.0.0.1:8081
RELAY_HOST=relay.example.com
RELAY_PING_URL=https://relay.example.com/ping
S3_ACCESS_KEY_ID=
S3_BUCKET=visp-snapshots
S3_ENDPOINT=https://example.upcloudobjects.com
S3_REGION=europe-1
S3_SECRET_ACCESS_KEY=
# Generate with: openssl rand -base64 32
PUBLISH_URL_ENCRYPTION_KEY=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
NODE_ENV=development
