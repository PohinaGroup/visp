{
	"name": "VISP",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"@better-auth/expo": "1.6.23",
			"dotenv": "^17.4.2",
			"zod": "^4.4.3",
			"typescript": "^6",
			"@types/bun": "^1.3.14",
			"elysia": "^1.4.29",
			"@trpc/server": "^11.18.0",
			"better-auth": "1.6.23",
			"evlog": "^2.19.2",
			"lucide-react": "^1.23.0",
			"next-themes": "^0.4.6",
			"react": "19.2.7",
			"react-dom": "19.2.7",
			"sonner": "^2.0.7",
			"tailwindcss": "^4.3.2",
			"@trpc/client": "^11.18.0",
			"@types/react": "^19.2.17",
			"@types/react-dom": "^19.2.3"
		}
	},
	"type": "module",
	"scripts": {
		"dev": "turbo run dev",
		"build": "turbo run build",
		"test": "bun test",
		"test:integration": "sh scripts/test-integration.sh",
		"check-types": "turbo run check-types",
		"dev:web": "turbo run dev -F web",
		"dev:server": "turbo run dev -F server",
		"db:push": "turbo run db:push -F @VISP/db",
		"db:studio": "turbo run db:studio -F @VISP/db",
		"db:generate": "turbo run db:generate -F @VISP/db",
		"db:migrate": "turbo run db:migrate -F @VISP/db",
		"check": "biome check --write .",
		"version:bump": "bash scripts/bump-release-version.sh",
		"prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
	},
	"dependencies": {
		"@VISP/env": "workspace:*",
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@VISP/config": "workspace:*",
		"@biomejs/biome": "^2.5.2",
		"@types/bun": "catalog:",
		"turbo": "^2.10.2",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.14"
}
